#!/usr/bin/env bash
# Verifies the secret-leak guard hook is working.
# Run this after install to confirm Claude Code won't leak secrets.

set -euo pipefail

HOOK="$HOME/.claude/hooks/guard-dangerous-commands.sh"

if [[ ! -x "$HOOK" ]]; then
  echo "FAIL: hook not found or not executable: $HOOK"
  exit 1
fi

# Feed a dangerous command pattern through the hook.
test_input='{"command": "rm -rf /"}'
if echo "$test_input" | "$HOOK" 2>/dev/null; then
  echo "FAIL: hook did not block dangerous command"
  exit 1
else
  echo "OK: guard hook is active and blocking dangerous commands"
fi
