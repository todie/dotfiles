#!/usr/bin/env bash
# theme — list or switch the active starship theme.
#
# Usage:
#   theme              # show current
#   theme list         # list available themes
#   theme set <name>   # switch to <name>
#   theme next         # cycle to next
#   theme prev         # cycle to previous
#   theme random       # roll the dice
#
# How it works: the active starship config at ~/.config/starship.toml is
# generated by concatenating two files from the dotfiles repo:
#
#   ~/projects/dotfiles/starship/base.toml          (layout — segments + format)
#   ~/projects/dotfiles/starship/themes/<name>.toml (palette only)
#
# The currently active theme name is stored in ~/.config/starship.theme so
# `theme show` can read it without parsing TOML.

set -euo pipefail

DOTFILES_STARSHIP="${DOTFILES_DIR:-$HOME/projects/dotfiles}/starship"
BASE="$DOTFILES_STARSHIP/base.toml"
THEMES_DIR="$DOTFILES_STARSHIP/themes"
ACTIVE_FILE="$HOME/.config/starship.toml"
THEME_STATE="$HOME/.config/starship.theme"

BOLD="$(tput bold 2>/dev/null || printf '')"
NC="$(tput sgr0 2>/dev/null || printf '')"
PINK="$(tput setaf 13 2>/dev/null || printf '')"
CYAN="$(tput setaf 14 2>/dev/null || printf '')"
DIM="$(tput setaf 8 2>/dev/null || printf '')"

themes() {
    find "$THEMES_DIR" -maxdepth 1 -type f -name '*.toml' -printf '%f\n' \
        | sed 's/\.toml$//' | sort
}

current() {
    if [[ -f "$THEME_STATE" ]]; then
        cat "$THEME_STATE"
    else
        echo "neon-dreams"
    fi
}

set_theme() {
    local name="$1"
    local target="$THEMES_DIR/${name}.toml"
    if [[ ! -f "$target" ]]; then
        printf "${PINK}theme not found:${NC} %s\n" "$name" >&2
        printf "available:\n" >&2
        themes | sed 's/^/  /' >&2
        return 1
    fi
    if [[ ! -f "$BASE" ]]; then
        printf "${PINK}missing base config:${NC} %s\n" "$BASE" >&2
        return 1
    fi
    mkdir -p "$(dirname "$ACTIVE_FILE")"
    {
        echo "# AUTO-GENERATED by 'theme set $name' on $(date -Iseconds)"
        echo "# DO NOT EDIT — regenerated whenever you switch themes."
        echo "# Edit base.toml or themes/<name>.toml in ~/projects/dotfiles/starship/."
        echo
        # Base first (owns layout + root-level keys). Theme second (appends
        # only the [palettes.neon_dreams] block — isolated from root keys).
        cat "$BASE"
        echo
        cat "$target"
    } > "$ACTIVE_FILE.tmp"
    mv "$ACTIVE_FILE.tmp" "$ACTIVE_FILE"
    echo "$name" > "$THEME_STATE"
    printf "${CYAN}▲${NC} active theme: ${BOLD}${PINK}%s${NC}\n" "$name"
    printf "${DIM}reload your shell:${NC} ${BOLD}exec \$SHELL${NC}\n"
}

cycle() {
    local direction="$1"
    local cur arr idx new
    cur=$(current)
    mapfile -t arr < <(themes)
    idx=-1
    for i in "${!arr[@]}"; do
        [[ "${arr[$i]}" == "$cur" ]] && { idx=$i; break; }
    done
    [[ $idx -lt 0 ]] && idx=0
    if [[ "$direction" == "next" ]]; then
        new="${arr[$(( (idx + 1) % ${#arr[@]} ))]}"
    else
        new="${arr[$(( (idx - 1 + ${#arr[@]}) % ${#arr[@]} ))]}"
    fi
    set_theme "$new"
}

case "${1:-show}" in
    show|status|"")
        printf "${BOLD}${CYAN}▲ active theme:${NC} ${PINK}%s${NC}\n" "$(current)"
        ;;
    list|ls)
        cur=$(current)
        printf "${BOLD}themes:${NC}\n"
        themes | while read -r name; do
            if [[ "$name" == "$cur" ]]; then
                printf "  ${PINK}● ${BOLD}%s${NC}\n" "$name"
            else
                printf "  ${DIM}○${NC} %s\n" "$name"
            fi
        done
        ;;
    set|use)
        if [[ $# -lt 2 ]]; then
            echo "usage: theme set <name>" >&2
            exit 1
        fi
        set_theme "$2"
        ;;
    next|n)        cycle next ;;
    prev|previous|p) cycle prev ;;
    random|rand|r)
        new=$(themes | shuf -n 1)
        set_theme "$new"
        ;;
    -h|--help|help)
        sed -n '2,12p' "$0" | sed 's/^# \?//'
        ;;
    *)
        # Bare name → treat as `theme set <name>`
        set_theme "$1"
        ;;
esac
